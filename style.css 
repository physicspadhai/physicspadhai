style.css
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}
body {
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    background: #f4f7fc;
    color: #333;
    line-height: 1.6;
}
.container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 20px;
}
h1 {
    text-align: center;
    color: #2c3e50;
    font-size: 2.5rem;
    margin: 20px 0 10px 0;
}
p {
    text-align: center;
    color: #555;
    font-size: 1.1rem;
    margin-bottom: 30px;
}
.book-title {
    text-align: center;
    color: #fff;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    padding: 12px;
    border-radius: 8px;
    margin: 40px 0 20px 0;
    font-size: 1.5rem;
    box-shadow: 0 4px 6px rgba(0,0,0,0.1);
}
.chapter-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 20px;
    margin-bottom: 30px;
}
.chapter-card {
    background: #fff;
    border: 2px solid #e0e0e0;
    border-radius: 10px;
    padding: 25px;
    text-decoration: none;
    color: #333;
    transition: all 0.3s ease;
    box-shadow: 0 2px 5px rgba(0,0,0,0.08);
}
.chapter-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 8px 15px rgba(102, 126, 234, 0.3);
    border-color: #667eea;
}
.chapter-card h3 {
    color: #667eea;
    font-size: 1.3rem;
    margin-bottom: 8px;
    text-align: center;
}
.chapter-card p {
    color: #555;
    font-size: 1rem;
    text-align: center;
    margin: 0;
}
footer {
    text-align: center;
    margin-top: 50px;
    padding: 30px 20px;
    background: #2c3e50;
    color: #fff;
    border-radius: 10px;
}
footer a {
    color: #74b9ff;
    text-decoration: none;
    margin: 0 10px;
    font-weight: 500;
}
footer a:hover {
    text-decoration: underline;
}
footer p {
    color: #b2bec3;
    margin-top: 15px;
    font-size: 0.9rem;
}
/* Mobile Responsive */
@media (max-width: 768px) {
    h1 {
        font-size: 1.8rem;
    }
    
    .book-title {
        font-size: 1.2rem;
    }
    
    .chapter-grid {
        grid-template-columns: 1fr;
    }
}